# Database Configuration
MYSQL_ROOT_PASSWORD=change_me
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_DATABASE=riskmonitor
MYSQL_USER=admin
MYSQL_PASSWORD=change_me

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO

# LLM（火山引擎 Coding API）
# 本项目默认只使用火山引擎 Coding API
# 请把真实密钥写入本地 .env 不要提交到 git
LLM_API_KEY=
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=ark-code-latest

# MCP Server Configuration
MCP_SERVER_NAME=RiskMonitor MultiAgent
MCP_SERVER_VERSION=0.1.0

# Memory Configuration
WORKING_MEMORY_BACKEND=memory
WORKING_MEMORY_MAX_LEN=2000
WORKING_MEMORY_TTL_S=86400
REDIS_URL=redis://localhost:6379/0
LONG_TERM_MEMORY_DB_URL=
MEMORY_SQLITE_PATH=

# Postgres Example
POSTGRES_DB=riskmonitor_memory
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
