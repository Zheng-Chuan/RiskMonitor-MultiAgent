WORKING_MEMORY_MAX_LEN=2000
WORKING_MEMORY_TTL_S=86400
REDIS_URL=redis://localhost:6379/0
LONG_TERM_MEMORY_DB_URL=
MEMORY_SQLITE_PATH=

# Postgres Example
POSTGRES_DB=riskmonitor_memory
