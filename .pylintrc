[MASTER]

# 仅检查项目代码与测试, 避免把虚拟环境等纳入扫描
ignore=CVS,.git,__pycache__,.mypy_cache,.pytest_cache,.venv

# 并行提升性能
jobs=0

[MESSAGES CONTROL]

# Google 风格导向: 保留关键规则, 关闭噪音较大的规则, 逐步收敛
# 说明:
# - 本项目包含 async, MCP framework, 与测试脚本, 需要一定灵活度
# - 后续可以按模块逐步打开更多规则

disable=
    missing-module-docstring,
    missing-function-docstring,
    missing-class-docstring,
    too-few-public-methods,
    duplicate-code,
    redefined-outer-name,
    broad-exception-caught,
    broad-exception-raised,
    fixme,

[FORMAT]

# Google Python Style Guide 推荐 80 列, 但工程里通常需要更高上限
max-line-length=120

[DESIGN]

max-args=10
max-locals=30
max-branches=25
max-statements=90
max-positional-arguments=6

[TYPECHECK]

# 第三方库可能缺少类型信息, 以工程可落地为优先
ignored-modules=pymysql
