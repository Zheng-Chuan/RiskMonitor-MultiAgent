{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentCommand v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "command_id",
    "target_agent",
    "action",
    "params",
    "timeout_ms",
    "expected_output_schema"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agent_command.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "target_agent": {
      "type": "string",
      "enum": ["system_engineer", "risk_analyst"]
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 0
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}

