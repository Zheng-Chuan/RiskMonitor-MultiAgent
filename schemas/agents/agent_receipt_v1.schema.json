{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentReceipt v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "command_id",
    "target_agent",
    "ok",
    "latency_ms",
    "evidence",
    "artifacts",
    "error",
    "output"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agent_receipt.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "target_agent": {
      "type": "string",
      "enum": ["system_engineer", "risk_analyst"]
    },
    "ok": {
      "type": "boolean"
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "error": {
      "type": ["string", "null"]
    },
    "output": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

