{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RiskEvent v1",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "correlation_id",
    "causation_id",
    "occurred_at",
    "producer",
    "severity",
    "category",
    "actionability",
    "confidence",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "risk_event.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": ["string", "null"]
    },
    "occurred_at": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["INFO", "WARNING", "CRITICAL"]
    },
    "category": {
      "type": "string",
      "enum": ["system", "business"]
    },
    "actionability": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

